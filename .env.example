# Supabase — PostgreSQL database + Auth + Storage
DATABASE_URL=postgresql://...           # Supabase connection string (transaction pooler, port 6543)
DIRECT_URL=postgresql://...            # Supabase direct connection (for migrations, port 5432)
NEXT_PUBLIC_SUPABASE_URL=https://...
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...          # Admin-only server-side operations

# Upstash Redis — correction form rate limiting (5/hour per IP)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Resend — transactional email (refresh notifications, correction approvals)
RESEND_API_KEY=re_...
ADMIN_EMAIL=admin@yourdomain.com       # Receives weekly refresh summary emails

# Pipeline — GitHub Actions webhook secret for POST /api/admin/refresh
PIPELINE_SECRET=...                    # Long random string — set same value in GitHub Secrets

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
